{
  "name": "nyc-commute",
  "version": "0.1.0",
  "private": true,
  "description": "Find NYC neighborhoods by public transit commute time and median rent",
  "scripts": {
    "install:all": "cd web && npm install && cd ../server && npm install",
    "dev": "cd web && npm run dev",
    "build": "cd web && npm run build",
    "start": "cd web && npm run start",
    "dev:web": "cd web && npm run dev",
    "dev:otp": "cd otp && java -Xmx4G -jar otp-2.5.0-shaded.jar --load .",
    "dev:legacy-client": "cd client && npm run dev",
    "dev:legacy-server": "cd server && npm run dev"
  },
  "dependencies": {
    "mongodb": "^7.2.0"
  }
}
