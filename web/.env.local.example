MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/nyc_commute?retryWrites=true&w=majority&appName=nyc-commute

# NYC — local OpenTripPlanner graph (port 8080)
OTP_PLAN_URL=http://localhost:8080/otp/routers/default/plan

# SF — Bay Area OTP graph (port 8081). Falls back to mock commutes if not running.
# See README for how to build the Bay Area graph using 511.org GTFS feeds.
OTP_PLAN_URL_SF=http://localhost:8081/otp/routers/default/plan
