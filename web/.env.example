# MongoDB Atlas connection string (required)
# Create a free cluster at https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nyc_commute?retryWrites=true&w=majority

# OTP routing engines (only needed for computing NEW commute times)
# Pre-cached commutes in MongoDB work without these.
# For cloud deployment, leave these blank — the app falls back to cached/mock data.
OTP_PLAN_URL=http://localhost:8080/otp/routers/default/plan
OTP_PLAN_URL_SF=http://localhost:8081/otp/routers/default/plan
